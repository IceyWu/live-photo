{
  "name": "live-photo",
  "version": "0.0.50",
  "type": "module",
  "description": "A LivePhoto viewer for web applications",
  "author": "Icey Wu <3128006406@qq.com>",
  "main": "dist/LivePhotoViewer.cjs.js",
  "module": "dist/LivePhotoViewer.esm.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/LivePhotoViewer.esm.js",
      "require": "./dist/LivePhotoViewer.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run release:check && pnpm exec changeset publish",
    "release:check": "pnpm run build"
  },
  "keywords": [
    "livephoto",
    "image",
    "viewer",
    "web",
    "javascript",
    "typescript",
    "vue",
    "react",
    "angular"
  ],
  "funding": "https://github.com/sponsors/iceywu",
  "homepage": "https://github.com/iceywu/live-photo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceywu/live-photo.git"
  },
  "bugs": {
    "url": "https://github.com/iceywu/live-photo/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.62.0",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
